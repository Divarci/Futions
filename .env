# Api
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=https://+:8080
API_PORT=5001

# Scheduler
DOTNET_ENVIRONMENT=Production

# Connections
SQL_CONNECTION_STRING=Server=...;Database=...;

# Redis
CACHE_CONFIG_HOST_AND_PORT=redis:6379
CACHE_CONFIG_ACCESS_KEY=
CACHE_CONFIG_SSL=false
CACHE_CONFIG_TIMEOUT=5000

# Outbox
OUTBOX_INTERVAL_IN_SECONDS=30
OUTBOX_BATCH_SIZE=20

# Authentication (Keycloak)
AUTH_AUDIENCE=account
AUTH_METADATA_ADDRESS=
AUTH_REQUIRE_HTTPS_METADATA=true
AUTH_VALID_ISSUER_0=
AUTH_VALID_ISSUER_1=

# Serilog
SERILOG_ADMIN_PASSWORD=