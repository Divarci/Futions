meta {
  name: Update Company
  type: http
  seq: 4
}

patch {
  url: {{baseUrl}}/api/v1/tenants/{{tenantId}}/companies/{{companyId}}
  body: json
  auth: none
}

body:json {
  {
    "name": "Updated Company Name",
    "address": {
